@page "/kontakt"

<PageTitle>Kontakt – FF Rastenfeld</PageTitle>

<div class="page-hero page-hero--sm">
    <div class="page-hero-content">
        <h1>Kontakt</h1>
        <p>So erreicht ihr uns</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="notruf-alert">
            <div class="notruf-alert-icon">🚨</div>
            <div>
                <h3>Im Notfall: 122 rufen!</h3>
                <p>Der Feuerwehr-Notruf 122 ist kostenlos und rund um die Uhr erreichbar. Bitte nur für echte Notfälle verwenden!</p>
                <a href="tel:122" class="btn btn-danger">122 anrufen</a>
            </div>
        </div>

        <div class="kontakt-layout">
            <!-- Info -->
            <div class="kontakt-info">
                <h2>Unsere Kontaktdaten</h2>

                <div class="kontakt-item">
                    <span class="kontakt-icon">📍</span>
                    <div>
                        <strong>Adresse</strong>
                        <p>Freiwillige Feuerwehr Rastenfeld<br />
                           Rastenfeld 178<br />
                           3532 Rastenfeld<br />
                           Niederösterreich, Österreich</p>
                    </div>
                </div>

                <div class="kontakt-item">
                    <span class="kontakt-icon">📧</span>
                    <div>
                        <strong>E-Mail</strong>
                        <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p>
                    </div>
                </div>

                <div class="kontakt-item">
                    <span class="kontakt-icon">🏛️</span>
                    <div>
                        <strong>Zugehörigkeit</strong>
                        <p>Abschnittsfeuerwehrkommando Krems<br />
                           NÖ Landesfeuerwehrverband</p>
                    </div>
                </div>

                <div class="kontakt-item">
                    <span class="kontakt-icon">📞</span>
                    <div>
                        <strong>Gemeinde Rastenfeld</strong>
                        <p>+43 (0)2826 / 289<br />
                           <a href="mailto:gemeinde@rastenfeld.at">gemeinde&#64;rastenfeld.at</a></p>
                    </div>
                </div>

                <div class="kontakt-item">
                    <span class="kontakt-icon">🗓️</span>
                    <div>
                        <strong>Übungsabende</strong>
                        <p>Jeden zweiten Freitag, 19:00 Uhr<br />
                           Im Feuerwehrhaus Rastenfeld</p>
                    </div>
                </div>
            </div>

            <!-- Formular -->
            <div class="kontakt-form-box">
                <h2>Nachricht senden</h2>
                @if (gesendet)
                {
                    <div class="form-success">
                        ✅ Deine Nachricht wurde gesendet! Wir melden uns bald.
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Name *</label>
                        <input type="text" @bind="formName" placeholder="Dein Name" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>E-Mail *</label>
                        <input type="email" @bind="formEmail" placeholder="deine@email.at" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Betreff</label>
                        <select @bind="formBetreff" class="form-input">
                            <option>Allgemeine Anfrage</option>
                            <option>Mitglied werden</option>
                            <option>Veranstaltung</option>
                            <option>Presse / Medien</option>
                            <option>Sonstiges</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Nachricht *</label>
                        <textarea @bind="formNachricht" rows="5" placeholder="Deine Nachricht..." class="form-input"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <p class="form-error">@formError</p>
                    }
                    <button class="btn btn-primary btn-full" @onclick="Submit">Nachricht senden 📨</button>
                }
            </div>
        </div>

        <!-- Karte Platzhalter -->
        <div class="map-placeholder">
            <div class="map-inner">
                <span class="map-pin">📍</span>
                <p><strong>FF Rastenfeld</strong><br />Rastenfeld 178, 3532 Rastenfeld</p>
                <a href="https://maps.google.com/?q=Feuerwehr+Rastenfeld+178,3532+Rastenfeld" target="_blank" class="btn btn-outline">
                    In Google Maps öffnen
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private string formName = "";
    private string formEmail = "";
    private string formBetreff = "Allgemeine Anfrage";
    private string formNachricht = "";
    private string formError = "";
    private bool gesendet = false;

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(formName) || string.IsNullOrWhiteSpace(formEmail) || string.IsNullOrWhiteSpace(formNachricht))
        {
            formError = "Bitte Name, E-Mail und Nachricht ausfüllen.";
            return;
        }
        formError = "";
        gesendet = true;
    }
}
